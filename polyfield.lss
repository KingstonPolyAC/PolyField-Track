; PolyField Track — FinishLynx LSS Script v2.0
; Outputs pipe-delimited text via UDP to PolyField Track on port 5001.
; Defaults: 9600,8,N,1

; --- Clock & Timing State ---

;;TimeArmed
\11\00armed|
\13\02%s\r\n

;;TimeRunning
\11\01%s|
\13\02%s\r\n

;;TimeUpdate
\11\01%s|
\13\02%s\r\n

;;TimeStopped
\11\01stopped:%s|
\13\02%s\r\n

;;TimePaused
\11\01paused:%s|
\13\02%s\r\n

;;TimeOfDay
\11\01timeofday|%s\r\n

; --- Wind (Raw mode — fires on every beam break, filter "no data" in receiver) ---

;;Wind
\12\01wind:%s\r\n

; --- Start List (sent when event is loaded, before gun) ---

;;StartListHeader
\13\00startlist-event|
\13\02%s
\13\00|round=
\13\05%s
\13\00|heat=
\13\06%s
\13\00|eventno=
\13\04%s\r\n

;;StartList
\14\00startlist|lane=
\14\02%s
\14\00|bib=
\14\03%s
\14\00|first=
\14\17%s
\14\00|last=
\14\18%s
\14\00|club=
\14\05%s\r\n

; --- Started (sent once gun fires — keeps start list visible during race) ---

;;StartedHeader
\13\00startlist-event|
\13\02%s
\13\00|round=
\13\05%s
\13\00|heat=
\13\06%s
\13\00|eventno=
\13\04%s\r\n

;;Started
\14\00startlist|lane=
\14\02%s
\14\00|bib=
\14\03%s
\14\00|first=
\14\17%s
\14\00|last=
\14\18%s
\14\00|club=
\14\05%s\r\n

; --- Results (Live) — sent each time results are updated ---

;;ResultsHeader
\13\00results-event|
\13\02%s
\13\00|round=
\13\05%s
\13\00|heat=
\13\06%s
\13\00|wind=
\13\03%s
\13\00|official=
\13\01%s\r\n

;;Results
\14\00result|place=
\14\01%s
\14\00|lane=
\14\02%s
\14\00|bib=
\14\03%s
\14\00|first=
\14\17%s
\14\00|last=
\14\18%s
\14\00|club=
\14\05%s
\14\00|time=
\14\06%s
\14\00|delta=
\14\07%s\r\n

;;ResultsTrailer
\13\00results-end\r\n
