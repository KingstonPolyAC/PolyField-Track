; --- Clock & Timing State ---

;;TimeArmed
\11\01armed|
\13\02%s\r\n

;;TimeRunning
\11\01%s|
\13\02%s\r\n

;;TimeUpdate
\11\01%s|
\13\02%s\r\n

;;TimeStopped
\11\01stopped:%s|
\13\02%s\r\n

;;TimePaused
\11\01paused:%s|
\13\02%s\r\n

;;TimeOfDay
\11\01timeofday|%s\r\n

; --- Wind ---
; Explicitly reset to Standard Data (\11\01) before printing wind
;;WindReading
\11\01wind:\W%2.2f\r\n

; --- Start List ---

;;StartListHeader
\11\01startlist-event|
\13\02%s\r\n

;;StartList
\11\01startlist|lane=\L|bib=\I|first=\F|last=\N|club=\A\r\n